# --- Gemini (required) ---
# You can also enter the key in the UI settings (sent per-request); this is the fallback.
GOOGLE_API_KEY=
# Override model ids if needed (defaults are the current ones, verified June 2026):
# VLM_FLASH_MODEL=gemini-3.5-flash
# VLM_PRO_MODEL=gemini-3.1-pro-preview

# --- Supabase: basketball annotation project mhbrsftxvxxtfgbajrlc (required for the "From Supabase" tab) ---
# Server-side, read-only. Prefer the service_role key so reads bypass RLS (the
# `games` table is RLS-protected for anon). Resolution order: SUPABASE_KEY ->
# SUPABASE_SERVICE_ROLE_KEY -> SUPABASE_ANON_KEY.
SUPABASE_URL=https://mhbrsftxvxxtfgbajrlc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# SUPABASE_KEY=           # optional explicit override (wins over the two above)

# --- AWS S3 (required to fetch/slice clips for the "From Supabase" tab) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
UBALL_VIDEO_BUCKET=uball-videos-production

# --- optional tuning ---
# VLM_FPS=5
# VLM_MEDIA_RESOLUTION=medium
# VLM_CLIP_PAD=3                 # seconds padded each side of a play's [start,end]
# VLM_PREFER_REMOTE_SLICE=1      # 1 = slice from S3 via presigned URL + HTTP range (no full download)
# VLM_S3_PRESIGN_TTL=3600        # presigned URL lifetime (seconds)
# VLM_EXTRACT_VF=scale=-2:720    # ffmpeg video filter for the sliced clip
# VLM_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
